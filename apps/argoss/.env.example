# Скопируйте этот файл в .env и заполните свои значения:
#   cp .env.example .env

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# API-ключ OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Ollama (локальный LLM)
# Лёгкая модель для слабых машин; замените на llama3:8b или другую при наличии ресурсов
OLLAMA_MODEL=llama3.2:1b
# Таймаут (сек) ожидания ответа от Ollama (по умолчанию 600)
OLLAMA_TIMEOUT=600

# Режим ИИ: auto — автоматический выбор (ollama → gemini → gpt → etc.)
ARGOS_AI_MODE=auto

# Grist P2P-хранилище (https://getgrist.com / self-hosted)
# API-ключ Grist (Settings → API key)
GRIST_API_KEY=your_grist_api_key_here
# URL сервера Grist (по умолчанию https://docs.getgrist.com)
GRIST_SERVER_URL=https://docs.getgrist.com
# ID документа Grist (из URL: /doc/<DOC_ID>).
GRIST_DOC_ID=your_grist_doc_id_here
# Альтернатива GRIST_DOC_ID: задайте одно из двух, GIST_ID используется только если GRIST_DOC_ID не задан.
# GIST_ID=your_grist_doc_id_here
# Шифрование записей перед сохранением в Grist: on / off (по умолчанию on)
GRIST_ENCRYPT=on

# ── Homeostasis & Self-Regulation (v1.4.0+) ──────────────────
ARGOS_HOMEOSTASIS=on
ARGOS_HOMEOSTASIS_INTERVAL=8
ARGOS_CURIOSITY=on
ARGOS_TASK_WORKERS=2
ARGOS_TASK_RPS_SYSTEM=8
ARGOS_TASK_RPS_IOT=6
ARGOS_TASK_RPS_AI=3
ARGOS_TASK_RPS_HEAVY=1

# ── Alignment & Safety ───────────────────────────────────────
ARGOS_ALIGN_BATCH=8
ARGOS_DRAFTER_CALIBRATION=on
ARGOS_ACCEPTANCE_FLOOR=0.55

# ── Remote Access ────────────────────────────────────────────
ARGOS_REMOTE_TOKEN=CHANGE_ME_IN_PRODUCTION

# ── Logging ──────────────────────────────────────────────────
ARGOS_LOG_LEVEL=INFO

# ── Shodan (https://account.shodan.io/) ──────────────────────
SHODAN_API_KEY=

# ── Hugging Face (https://huggingface.co/settings/tokens) ────
HUGGINGFACE_TOKEN=hf_
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ── Slack (https://api.slack.com/apps) ───────────────────────
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-
SLACK_DEFAULT_CHANNEL=#general

# ── AI Провайдеры (все бесплатные) ───────────────────────────────────────────
# Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (Llama 3): https://console.groq.com/keys
GROQ_API_KEY=

# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# xAI Grok ($25/мес бесплатно): https://console.x.ai/
XAI_API_KEY=

# GigaChat (Сбер): https://developers.sber.ru/studio
GIGACHAT_ACCESS_TOKEN=

# YandexGPT: https://console.yandex.cloud/
YANDEX_IAM_TOKEN=
YANDEX_FOLDER_ID=

# IBM WatsonX: https://cloud.ibm.com/watsonx
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Ollama (локально): https://ollama.com
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Настройки роутера
ARGOS_PROVIDER_COOLDOWN=60

# ── Мультимодельный режим ─────────────────────────────────────────────────────
# Основная модель
OLLAMA_MODEL=llama3

# Дополнительные модели (через запятую)
# Пример: OLLAMA_MODELS=llama3,mistral:7b,codellama:13b
OLLAMA_MODELS=

# Быстрая модель для простых команд
OLLAMA_FAST_MODEL=tinyllama

# Режим consensus (опрашивать N моделей параллельно)
ARGOS_CONSENSUS_MODE=off
ARGOS_CONSENSUS_N=2

# Основной облачный провайдер (gemini/groq/deepseek/xai)
ARGOS_PRIMARY_CLOUD=gemini

# ── Три модели Ollama ─────────────────────────────────────────────────────────
# Быстрая локальная (простые задачи, команды)
OLLAMA_FAST_MODEL=tinyllama

# Умная локальная (диалоги, анализ)
OLLAMA_MODEL=llama3.2:3b

# Облачная через Ollama (сложные задачи, 120B параметров)
OLLAMA_CLOUD_MODEL=gpt-oss:120b-cloud

# Таймауты (секунды)
OLLAMA_TIMEOUT_FAST=30
OLLAMA_TIMEOUT_SMART=120
OLLAMA_TIMEOUT_CLOUD=180
