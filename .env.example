# ╔══════════════════════════════════════════════════════════════╗
# ║  ARGOS Universal OS v2.1 — Полный .env шаблон               ║
# ║  Скопируй нужные строки и заполни своими значениями          ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Telegram ──────────────────────────────────────────────────────────────────
# Токен бота: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Твой Telegram ID: @userinfobot → /start
USER_ID=

# ── Ollama (три модели) ───────────────────────────────────────────────────────
# Адрес сервера Ollama
OLLAMA_HOST=http://localhost:11434

# Умная локальная модель (диалоги, анализ)
OLLAMA_MODEL=llama3.2:3b

# Быстрая локальная модель (простые команды)
OLLAMA_FAST_MODEL=tinyllama

# Облачная модель через Ollama (сложные задачи, 120B)
OLLAMA_CLOUD_MODEL=gpt-oss:120b-cloud

# Все три через запятую
OLLAMA_MODELS=tinyllama,llama3.2:3b,gpt-oss:120b-cloud

# Таймауты (секунды)
OLLAMA_TIMEOUT=600
OLLAMA_TIMEOUT_FAST=30
OLLAMA_TIMEOUT_SMART=120
OLLAMA_TIMEOUT_CLOUD=180

# ── AI Провайдеры (бесплатные) ────────────────────────────────────────────────

# Gemini (Google) — 15 RPM, 1500/день
# Ключ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (Llama 3) — 30 RPM, 14400/день
# Ключ: https://console.groq.com/keys
GROQ_API_KEY=

# DeepSeek — щедрый лимит
# Ключ: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# xAI Grok — $25/мес бесплатно
# Ключ: https://console.x.ai/
XAI_API_KEY=

# GigaChat (Сбер) — 60 RPM
# Ключ: https://developers.sber.ru/studio
GIGACHAT_ACCESS_TOKEN=
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# YandexGPT — 300 RPH
# Ключ: https://console.yandex.cloud/
YANDEX_IAM_TOKEN=
YANDEX_FOLDER_ID=

# IBM WatsonX — 300k токенов/мес
# Ключ: https://cloud.ibm.com/watsonx
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# OpenAI — $5 стартовый баланс
# Ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── AI Router настройки ───────────────────────────────────────────────────────
# Основной облачный провайдер (gemini/groq/deepseek/xai)
ARGOS_PRIMARY_CLOUD=gemini

# Cooldown провайдера после ошибки (секунды)
ARGOS_PROVIDER_COOLDOWN=60

# Режим автопереключения
ARGOS_AI_MODE=auto

# ── Мультимодельный режим ─────────────────────────────────────────────────────
# Параллельный опрос двух моделей
ARGOS_PARALLEL_MODE=off

# Consensus mode (опрос N моделей, лучший ответ)
ARGOS_CONSENSUS_MODE=off
ARGOS_CONSENSUS_N=2

# ── Системные модули ──────────────────────────────────────────────────────────
ARGOS_HOMEOSTASIS=on
ARGOS_CURIOSITY=on
ARGOS_VOICE_DEFAULT=off
ARGOS_TASK_WORKERS=2
ARGOS_LOG_LEVEL=INFO

# Безопасность REST API
# Любая строка — защитит /api/command
ARGOS_REMOTE_TOKEN=

# Сетевой секрет P2P
ARGOS_NETWORK_SECRET=argos_secret_2026

# ── GitHub (для автопуша) ─────────────────────────────────────────────────────
# Токен: https://github.com/settings/tokens → repo scope
GITHUB_TOKEN=
GIST_ID=

# ── IoT / MQTT ────────────────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# Zigbee (zigbee2mqtt)
ZIGBEE_MQTT_HOST=localhost
ZIGBEE_MQTT_PORT=1883

# LoRa
LORA_PORT=/dev/ttyAMA0
LORA_BAUD=9600

# Modbus
MODBUS_MODE=rtu
MODBUS_PORT=/dev/ttyUSB0

# Home Assistant
HA_URL=http://localhost:8123
HA_TOKEN=

# Tasmota
TASMOTA_MQTT_HOST=localhost

# ── GSM / SIM800C ─────────────────────────────────────────────────────────────
# Платформа: rpi / esp32 / linux
SIM800C_PLATFORM=rpi
SIM800C_PORT=/dev/ttyAMA0
SIM800C_BAUD=9600
SIM800C_PHONE=
SIM800C_BALANCE_USSD=*100#
SIM_APN=internet

# ── Grist (P2P хранилище знаний) ─────────────────────────────────────────────
GRIST_API_KEY=
GRIST_SERVER_URL=https://docs.getgrist.com
GRIST_DOC_ID=
GIST_ID=
GRIST_ENCRYPT=on

# ── IBM Cloud Object Storage (необязательно) ──────────────────────────────────
# Оставь пустым если не используешь — ARGOS пропустит автоматически
IBM_COS_ENDPOINT=
IBM_COS_API_KEY=
IBM_COS_RESOURCE_INSTANCE_ID=
IBM_COS_ACCESS_KEY_ID=
IBM_COS_SECRET_ACCESS_KEY=
IBM_COS_BUCKET=

# ── Публикация на PyPI (необязательно) ───────────────────────────────────────
PYPI_TOKEN=

# ── SDR / AirSnitch (необязательно) ──────────────────────────────────────────
ARGOS_SDR_AUTOSTART=off
