# Скопируйте этот файл в .env и заполните свои значения:
#   cp .env.example .env

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# API-ключ OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# ── Ollama (локальный LLM) ────────────────────────────────────────────────────
# Основная модель (собрать: ollama create argos-core -f Argos.modelfile)
OLLAMA_MODEL=argos-core
# Быстрая модель для рефлексов (простые команды, мгновенный ответ)
OLLAMA_FAST_MODEL=tinyllama
# Таймаут (сек) ожидания ответа от Ollama (по умолчанию 600)
OLLAMA_TIMEOUT=600
# Хост Ollama
OLLAMA_HOST=http://localhost:11434

# ── AMD GPU (RX 580 + RX 560) — Double-Brain Split ───────────────────────────
# Загрузить все слои в GPU (99 = максимум)
OLLAMA_NUM_GPU=99
# Разрешить Ollama держать 2 модели одновременно (RX 580 + RX 560)
OLLAMA_MAX_LOADED_MODELS=2
# Один параллельный чат = отдать все 8GB RX 580 одному Аргосу
OLLAMA_NUM_PARALLEL=1
# Отключить Intel GPU от вычислений (если есть Intel iGPU)
OLLAMA_INTEL_GPU=0
# Для AMD ROCm (Linux): видимые GPU (0=RX580, 1=RX560)
# HIP_VISIBLE_DEVICES=0,1
# Максимум VRAM для Ollama (MB). 8192 = RX 580 full 8GB
# OLLAMA_MAX_VRAM=8192

# ── Режим скорости и производительности ──────────────────────────────────────
# performance / balanced / economy
ARGOS_SPEED_MODE=performance
# num_ctx для Ollama (16384 = RX 580 полная память, 8192 = осторожный режим)
ARGOS_NUM_CTX=16384
# Порог CPU для idle-обучения (%)
ARGOS_IDLE_CPU_THRESHOLD=30
# Интервал автообучения (сек). 1800 = 30 мин
ARGOS_LEARN_INTERVAL=1800

# ── Режим ИИ ─────────────────────────────────────────────────────────────────
# auto — автоматический выбор (ollama → gemini → gpt → etc.)
ARGOS_AI_MODE=auto

# ── Модули (on/off) ───────────────────────────────────────────────────────────
ARGOS_HOMEOSTASIS=on
ARGOS_CURIOSITY=on
ARGOS_SUSTAIN=on

# ── SDR / Радиосканер (AirSnitch) ────────────────────────────────────────────
# Автозапуск AirSnitch при старте AWA-Core (rtl_433 должен быть установлен)
# Linux/Docker: sudo apt install rtl-433 | Windows: rtl_433.exe в PATH
ARGOS_SDR_AUTOSTART=off

# ── Grist P2P-хранилище ──────────────────────────────────────────────────────
GRIST_API_KEY=your_grist_api_key_here
GRIST_SERVER_URL=https://docs.getgrist.com
GRIST_DOC_ID=your_grist_doc_id_here
GRIST_ENCRYPT=on

# ── AI Провайдеры (все бесплатные) ───────────────────────────────────────────
# Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (Llama 3): https://console.groq.com/keys
GROQ_API_KEY=

# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# xAI Grok ($25/мес бесплатно): https://console.x.ai/
XAI_API_KEY=

# GigaChat (Сбер): https://developers.sber.ru/studio
GIGACHAT_ACCESS_TOKEN=

# YandexGPT: https://console.yandex.cloud/
YANDEX_IAM_TOKEN=
YANDEX_FOLDER_ID=

# IBM WatsonX: https://cloud.ibm.com/watsonx
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Ollama (локально): https://ollama.com
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Настройки роутера
ARGOS_PROVIDER_COOLDOWN=60

# ── Мультимодельный режим ─────────────────────────────────────────────────────
# Основная модель
OLLAMA_MODEL=llama3

# Дополнительные модели (через запятую)
# Пример: OLLAMA_MODELS=llama3,mistral:7b,codellama:13b
OLLAMA_MODELS=

# Быстрая модель для простых команд
OLLAMA_FAST_MODEL=tinyllama

# Режим consensus (опрашивать N моделей параллельно)
ARGOS_CONSENSUS_MODE=off
ARGOS_CONSENSUS_N=2

# Основной облачный провайдер (gemini/groq/deepseek/xai)
ARGOS_PRIMARY_CLOUD=gemini

# ── Три модели Ollama ─────────────────────────────────────────────────────────
# Быстрая локальная (простые задачи, команды)
OLLAMA_FAST_MODEL=tinyllama

# Умная локальная (диалоги, анализ)
OLLAMA_MODEL=llama3.2:3b

# Облачная через Ollama (сложные задачи, 120B параметров)
OLLAMA_CLOUD_MODEL=gpt-oss:120b-cloud

# Таймауты (секунды)
OLLAMA_TIMEOUT_FAST=30
OLLAMA_TIMEOUT_SMART=120
OLLAMA_TIMEOUT_CLOUD=180
